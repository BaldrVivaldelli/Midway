{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidWay",
  "version": "0.1.0",
  "identifier": "com.aatv.midway",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Midway",
        "width": 1520,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Minimal desktop API client for developers",
    "longDescription": "Midway is a minimalist desktop API client for developers focused on progressive disclosure, low cognitive load and fast request workflows.",
    "license": "MIT",
    "publisher": "Midway"
  }
}
