{
  "name": "midway",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "npm run test:node && npm run test:ui",
    "size:check": "node scripts/check-budgets.mjs",
    "build:ci": "npm run build && npm run test && npm run size:check",
    "tauri": "tauri",
    "release:checksums": "node scripts/release/generate-checksums.mjs release-artifacts out/SHA256SUMS.txt",
    "release:updater-json": "node scripts/release/run-generate-updater-json.mjs",
    "tauri:build:release:stable": "npm run release:prepare && tauri build --config src-tauri/tauri.release.generated.json",
    "tauri:build:release:beta": "MIDWAY_RELEASE_CHANNEL=beta npm run release:prepare && tauri build --config src-tauri/tauri.release.generated.json --config src-tauri/tauri.beta.generated.json",
    "test:node": "node --test tests/*.test.mjs",
    "test:ui": "vitest run",
    "release:prepare": "node scripts/release/render-tauri-config.mjs"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@uiw/react-codemirror": "^4.25.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.1"
  }
}
